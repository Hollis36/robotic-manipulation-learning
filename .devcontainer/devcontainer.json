{
  "name": "Robotic Manipulation Online Lab",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install -r requirements-book.txt && python -m pip install -r requirements-online.txt && python -m pip install -e .",
  "forwardPorts": [
    3000,
    8000,
    8888
  ],
  "portsAttributes": {
    "3000": {
      "label": "Jupyter Book"
    },
    "8000": {
      "label": "Online Platform"
    },
    "8888": {
      "label": "Jupyter"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "yzhang.markdown-all-in-one"
      ]
    }
  }
}
